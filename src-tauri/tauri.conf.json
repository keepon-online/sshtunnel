{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ssh-tunnel-manager",
  "version": "0.1.0",
  "identifier": "com.top.sshtunnel",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SSH Tunnel Manager",
        "center": true,
        "width": 1280,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png", "icons/icon.svg"]
  }
}
